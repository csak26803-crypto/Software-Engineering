classDiagram
    class CATALOG {
        <<Global Dictionary>>
        +dict T001
        +dict T002
        +dict T003...
    }

    class CartItem {
        <<Dictionary>>
        +String ticket_id
        +String name
        +int price
        +int quantity
        +String option
        +int subtotal
    }

    class Cart {
        +List~dict~ items
        +add_item(ticket_id, quantity, option)
        +remove_item(ticket_id, quantity)
        +clear_cart()
        +get_total() int
        +display_cart()
        +export_data() String
    }

    class QRCodeModule {
        <<Module>>
        +generate_qr_from_json(json_data, output_filename)
    }

    class AppModule {
        <<Streamlit Web App>>
        +load_catalog_safely()
        +st.session_state
    }

    AppModule --> CATALOG : load_catalog_safely()で取得
    AppModule *-- Cart : st.session_state.cart として保持
    Cart "1" *-- "*" CartItem : itemsリスト内に保持
    AppModule ..> QRCodeModule : 注文確定時に呼び出し
